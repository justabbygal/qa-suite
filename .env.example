# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Public base URL of the application (used by Better Auth for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------

# URL where Better Auth endpoints are mounted (must match NEXT_PUBLIC_APP_URL
# in development; set to your production domain in production)
BETTER_AUTH_URL=http://localhost:3000

# Secret key for signing session tokens and cookies.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# ---------------------------------------------------------------------------
# Database (Better Auth — direct PostgreSQL connection)
# ---------------------------------------------------------------------------

# Direct PostgreSQL connection string to your Supabase project.
# Found in: Supabase Dashboard → Settings → Database → Connection string (URI)
# Use the "Session mode" (port 5432) connection — NOT the transaction pooler —
# so Better Auth can use transactions and advisory locks.
DATABASE_URL=postgresql://postgres:[password]@[project-ref].supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# Supabase (existing — used by permission service and file uploads)
# ---------------------------------------------------------------------------

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co

# Service role key (server-side only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
