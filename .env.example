# ============================================================
# Fruition QA Suite - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.
# ============================================================


# ------------------------------------------------------------
# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ------------------------------------------------------------

# Your Supabase project URL (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never expose to the browser
# Used by API routes that need elevated database access
SUPABASE_SERVICE_ROLE_KEY=

# Direct PostgreSQL connection string (used by Better Auth for migrations/queries)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=


# ------------------------------------------------------------
# Better Auth (required)
# Docs: https://www.better-auth.com/docs/installation
# ------------------------------------------------------------

# A long, random secret used to sign session tokens
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The canonical URL of your app (no trailing slash)
# Must match the deployment URL in production
BETTER_AUTH_URL=http://localhost:3000


# ------------------------------------------------------------
# Application (required)
# ------------------------------------------------------------

# The public-facing URL of the app (no trailing slash)
# Used to build absolute URLs in emails and invite links
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ------------------------------------------------------------
# Email — Resend (required for invite flows)
# Get your API key from: https://resend.com/api-keys
# ------------------------------------------------------------

# Resend API key
RESEND_API_KEY=

# The "from" address for outgoing emails
# Must be a verified domain in your Resend account
EMAIL_FROM=noreply@yourdomain.com


# ------------------------------------------------------------
# Internal API security
# ------------------------------------------------------------

# A shared secret used to authenticate requests to internal-only endpoints
# (e.g. /api/invites/health). Generate with: openssl rand -hex 32
INTERNAL_API_KEY=


# ------------------------------------------------------------
# Development helpers (optional, local only)
# ------------------------------------------------------------

# Default organization ID injected during local development
# to avoid needing a real auth session when testing the UI
NEXT_PUBLIC_DEV_ORG_ID=dev-org
